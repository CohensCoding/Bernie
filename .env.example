SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Server-side only (never NEXT_PUBLIC_*). Used by /api/ingest/extract via src/lib/openai/server.ts
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

# Optional: the OpenAI Node SDK reads these when set (see node_modules/openai client constructor).
# Use when your key is scoped to a specific org/project or billing is tied to a project.
# OPENAI_ORG_ID=
# OPENAI_PROJECT_ID=

# Optional: defaults to https://api.openai.com/v1
# OPENAI_BASE_URL=

