SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Server-side only (never NEXT_PUBLIC_*). Used by /api/ingest/extract via src/lib/openai/server.ts
# and by Layer 2 identity parsing (src/lib/layer2/identity/parse.ts).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

# Optional: the OpenAI Node SDK reads these when set (see node_modules/openai client constructor).
# Use when your key is scoped to a specific org/project or billing is tied to a project.
# OPENAI_ORG_ID=
# OPENAI_PROJECT_ID=

# Optional: defaults to https://api.openai.com/v1
# OPENAI_BASE_URL=

# ==========================================================
# Layer 2 — Comp & FMV intelligence (docs/LAYER_2_SPEC.md)
# ==========================================================

# eBay official APIs (Layer 2). The adapter mints an *application* token
# on demand via the `client_credentials` grant using the same CLIENT_ID /
# CLIENT_SECRET / ENV that Layer 1 uses for its user-token flow — so the
# four lines below are the minimum required for Layer 2 eBay calls.
#   EBAY_CLIENT_ID, EBAY_CLIENT_SECRET, EBAY_REDIRECT_URI, EBAY_ENV
# These already live in your .env.local for Layer 1; no duplication.
#
# Optional overrides:
#   EBAY_OAUTH_TOKEN — paste a static token to skip mint-on-demand
#     (useful for dev; tokens are valid ~2h). Leave blank in production.
#   EBAY_MARKETPLACE_INSIGHTS_ENABLED — set to `true` only after eBay
#     approves your app for the buy.marketplace.insights scope. While
#     false, the adapter falls back to Browse (active listings, not
#     FMV-eligible). See docs/LAYER_2_DECISIONS.md D4 and D9.
#   EBAY_APP_ID / EBAY_CERT_ID / EBAY_DEV_ID — informational only;
#     Bernie does not use these (they're for the deprecated Trading API).
EBAY_OAUTH_TOKEN=
EBAY_MARKETPLACE_INSIGHTS_ENABLED=false

# Phase 3+ — Ximilar photo identification.
XIMILAR_API_TOKEN=

# Phase 4 — optional comp sources.
CARDHEDGE_API_KEY=
PSA_API_TOKEN=

